{
  "name": "docs-mcp",
  "version": "0.3.12",
  "description": "Read and write Kuaishou internal Docs pages (docs.corp.kuaishou.com)",
  "mcpServers": {
    "docs": {
      "command": "uv",
      "args": ["run", "--with", "mcp>=1.26.0", "--with", "websockets>=12.0", "--with", "browser-cookie3>=0.20.1", "--with", "requests>=2.32.5", "--with", "markdownify>=0.14.1", "python", "${CLAUDE_PLUGIN_ROOT}/docs_mcp_server.py"]
    }
  }
}
